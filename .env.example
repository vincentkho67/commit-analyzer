# Copy this file to the SHARED PARENT directory as ../.env
# (one level ABOVE this repo, i.e. secondtalent/.env) — NOT into the repo itself.
# The analyzer deliberately loads keys from the secondtalent/ parent dir so that
# multiple sibling projects can share one set of credentials.
#
#   cp .env.example ../.env   &&   $EDITOR ../.env
#
# GitHub personal access token. Raises the API rate limit to 5000/hr and
# enables private-repo access. Needs "repo" scope for private repos.
GITHUB_TOKEN=ghp_your_personal_access_token_here

# OpenAI API key, used for GPT-4o quality scoring + time estimation.
OPENAI_API_KEY=sk-your_openai_key_here
